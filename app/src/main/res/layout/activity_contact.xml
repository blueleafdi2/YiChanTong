<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">
    <com.google.android.material.appbar.AppBarLayout android:layout_width="match_parent" android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar android:id="@+id/toolbar"
            android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
            android:background="@color/primary" app:titleTextColor="@color/on_primary"
            app:navigationIconTint="@color/on_primary" app:title="联系法律专家" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="12dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/surface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📞 全国法律服务热线" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/text_primary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp"
                        android:text="12348" android:textSize="32sp" android:textStyle="bold" android:textColor="@color/primary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp"
                        android:text="全国统一法律援助热线（免费）\n工作时间：周一至周五 9:00-17:00"
                        android:textSize="13sp" android:textColor="@color/text_secondary" android:lineSpacingMultiplier="1.4" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btn_call_12348"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="12dp" android:text="拨打 12348" app:backgroundTint="@color/primary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- WeChat QR Code Card -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="12dp" app:cardCornerRadius="12dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/surface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp" android:gravity="center_horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💬 微信扫码咨询" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/text_primary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp"
                        android:text="扫描下方二维码或长按保存图片" android:textSize="13sp" android:textColor="@color/text_secondary" />

                    <ImageView
                        android:id="@+id/wechat_qr_image"
                        android:layout_width="280dp"
                        android:layout_height="280dp"
                        android:layout_marginTop="16dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="微信二维码"
                        android:clickable="true"
                        android:focusable="true" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="12dp" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="微信号：LawServicePro" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="8dp">
                        <com.google.android.material.button.MaterialButton android:id="@+id/btn_copy_wechat"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:layout_marginEnd="4dp" android:text="复制微信号" app:backgroundTint="#07C160" />
                        <com.google.android.material.button.MaterialButton android:id="@+id/btn_save_qr"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:layout_marginStart="4dp" android:text="保存二维码"
                            style="@style/Widget.Material3.Button.OutlinedButton" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="12dp" app:cardCornerRadius="12dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/surface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🏛️ 中国法律服务网" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/text_primary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp"
                        android:text="网址：www.12348.gov.cn\n\n提供免费法律咨询、法律援助申请、公证服务、司法鉴定等一站式法律服务"
                        android:textSize="14sp" android:textColor="@color/text_secondary" android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="12dp" app:cardCornerRadius="12dp" app:cardElevation="2dp" app:cardBackgroundColor="#FFF8E1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💡 温馨提示" android:textSize="16sp" android:textStyle="bold" android:textColor="#F57F17" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp"
                        android:text="1. 遗产继承纠纷建议先尝试家庭协商\n2. 协商不成可申请人民调解\n3. 调解不成可向法院提起诉讼\n4. 经济困难可申请法律援助（免费）\n5. 选择律师时建议查验执业证"
                        android:textSize="14sp" android:textColor="@color/text_primary" android:lineSpacingMultiplier="1.5" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="16dp" android:text="@string/disclaimer"
                android:textColor="@color/text_hint" android:textSize="11sp"
                android:gravity="center" android:lineSpacingMultiplier="1.3" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
