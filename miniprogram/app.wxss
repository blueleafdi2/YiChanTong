/* 遗产通 — 全局样式 */

/* Design Tokens */
page {
  --primary: #2B5F8A;
  --primary-light: #3A7CB8;
  --primary-dark: #1A3D5C;
  --gold: #C69C6D;
  --gold-light: #E8D5B5;
  --accent: #B33A3A;
  --bg: #F7F7F5;
  --surface: #FFFFFF;
  --surface-alt: #F0EDE8;
  --text-primary: #1A1A1A;
  --text-secondary: #666666;
  --text-hint: #999999;
  --border: #E8E5E0;
  --success: #2E7D32;
  --shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);

  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg);
  line-height: 1.6;
}

/* Typography */
.h1 { font-size: 40rpx; font-weight: 700; line-height: 1.3; }
.h2 { font-size: 34rpx; font-weight: 600; line-height: 1.4; }
.h3 { font-size: 30rpx; font-weight: 600; line-height: 1.4; }
.body { font-size: 28rpx; }
.caption { font-size: 24rpx; color: var(--text-secondary); }
.mini { font-size: 22rpx; color: var(--text-hint); }

/* Card */
.card {
  background: var(--surface);
  border-radius: 16rpx;
  box-shadow: var(--shadow);
  margin: 16rpx 24rpx;
  padding: 28rpx;
  overflow: hidden;
}

.card-flat {
  background: var(--surface);
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  margin: 12rpx 24rpx;
  padding: 24rpx;
}

/* Tag / Chip */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin: 4rpx 8rpx 4rpx 0;
  background: var(--gold-light);
  color: var(--primary-dark);
}

.tag-primary {
  background: rgba(43,95,138,0.1);
  color: var(--primary);
}

.tag-accent {
  background: rgba(179,58,58,0.1);
  color: var(--accent);
  font-weight: 600;
}

/* Button */
.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border: none;
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 12rpx;
  padding: 18rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-gold {
  background: linear-gradient(135deg, var(--gold), #D4A96A);
  color: #fff;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border: none;
}

/* Section */
.section {
  padding: 28rpx 24rpx 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 32rpx;
  background: var(--gold);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

/* Divider */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 16rpx 0;
}

/* Search bar */
.search-wrap {
  display: flex;
  align-items: center;
  background: var(--surface);
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
  margin: 16rpx 24rpx;
  box-shadow: var(--shadow);
}

.search-wrap .icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  opacity: 0.4;
}

.search-wrap input {
  flex: 1;
  font-size: 28rpx;
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-state .icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-state .text {
  font-size: 28rpx;
  color: var(--text-hint);
  text-align: center;
}

/* Keyword highlight */
.kw {
  color: var(--accent);
  font-weight: 700;
}

/* Law link */
.law-ref {
  color: var(--primary);
  font-weight: 500;
  text-decoration: underline;
  text-decoration-color: rgba(43,95,138,0.3);
}

/* Scroll tabs */
.tab-scroll {
  white-space: nowrap;
  padding: 16rpx 24rpx;
}

.tab-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 12rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--surface);
  border: 1rpx solid var(--border);
}

.tab-item.active {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
  font-weight: 500;
}

/* Loading */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 40rpx;
}

/* Safe area bottom */
.safe-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
}

/* Flex helpers */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }

/* Action bar for detail pages */
.action-bar {
  display: flex;
  gap: 24rpx;
  padding-top: 24rpx;
  padding-bottom: 16rpx;
  border-top: 1rpx solid var(--border);
  margin-top: 24rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  border-radius: 24rpx;
  background: var(--surface-alt);
  font-size: 26rpx;
}

.action-btn:active {
  opacity: 0.7;
}

.action-icon {
  font-size: 28rpx;
}

.action-label {
  color: var(--text-primary);
  font-weight: 500;
}

/* Spacing */
.mt-sm { margin-top: 8rpx; }
.mt-md { margin-top: 16rpx; }
.mt-lg { margin-top: 32rpx; }
.mb-sm { margin-bottom: 8rpx; }
.mb-md { margin-bottom: 16rpx; }
.px { padding: 0 24rpx; }
