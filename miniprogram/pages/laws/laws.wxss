.page {
  min-height: 100vh;
  background: #f7f7f5;
  display: flex;
  flex-direction: column;
}

.tab-bar {
  flex-shrink: 0;
  width: 100%;
  background: #ffffff;
  border-bottom: 1rpx solid #e8e5e0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tab-inner {
  display: inline-flex;
  padding: 20rpx 24rpx 16rpx;
  gap: 12rpx;
  white-space: nowrap;
}

.tab-pill {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 28rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #666666;
  background: #f7f7f5;
  border: 1rpx solid #e8e5e0;
  flex-shrink: 0;
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tab-pill.active {
  background: #2b5f8a;
  color: #ffffff;
  border-color: #2b5f8a;
  font-weight: 500;
}

.list-scroll {
  flex: 1;
  height: 0;
  padding-top: 16rpx;
}

.law-card {
  margin: 0 24rpx 20rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.law-card:active {
  opacity: 0.92;
}

.law-card-top {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.law-article {
  font-size: 24rpx;
  font-weight: 600;
  color: #2b5f8a;
}

.law-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.45;
}

.law-tags {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.law-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(198, 156, 109, 0.2);
  color: #1a3d5c;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.safe-bottom {
  height: calc(env(safe-area-inset-bottom) + 32rpx);
}
