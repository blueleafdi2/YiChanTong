.page {
  min-height: 100vh;
  background: #F7F7F5;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.avatar-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #2B5F8A 0%, #3A7CB8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(43, 95, 138, 0.35);
}

.avatar-placeholder {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.user-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.user-desc {
  font-size: 24rpx;
  color: #999999;
}

.menu-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  min-height: 96rpx;
  box-sizing: border-box;
}

.menu-item:active {
  background: #F7F7F5;
}

.menu-icon {
  font-size: 34rpx;
  margin-right: 20rpx;
  width: 44rpx;
  text-align: center;
}

.menu-title {
  flex: 1;
  font-size: 30rpx;
  color: #1A1A1A;
}

.menu-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #667EEA, #764BA2);
  color: #ffffff;
  border-radius: 16rpx;
  margin-left: auto;
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  font-weight: 300;
}

.menu-divider {
  height: 1rpx;
  background: #E8E5E0;
  margin-left: 88rpx;
}

.about-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 28rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border-left: 6rpx solid #C69C6D;
}

.about-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #2B5F8A;
  margin-bottom: 12rpx;
}

.about-version {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.about-body {
  display: block;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.about-stats {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.55;
}

.about-divider {
  height: 1rpx;
  background: #E8E5E0;
  margin: 24rpx 0 20rpx;
}

.about-sources-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.source-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.source-line {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
}

.privacy-wrap {
  display: flex;
  justify-content: center;
  padding: 8rpx 0 24rpx;
}

.privacy-btn {
  font-size: 28rpx;
  color: #2B5F8A;
  text-decoration: underline;
  text-decoration-color: rgba(43, 95, 138, 0.35);
  padding: 16rpx 24rpx;
}
