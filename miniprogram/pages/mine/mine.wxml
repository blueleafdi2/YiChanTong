<view class="page safe-bottom">
  <view class="user-card">
    <view class="avatar-wrap">
      <text class="avatar-placeholder">遗</text>
    </view>
    <view class="user-meta">
      <text class="user-name">遗产通用户</text>
      <text class="user-desc">本地学习 · 无需登录</text>
    </view>
  </view>

  <view class="menu-card">
    <view class="menu-item" data-url="/subpkg/favorites/favorites" bindtap="onMenuTap">
      <text class="menu-icon">⭐</text>
      <text class="menu-title">我的收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider" />
    <view class="menu-item" data-url="/subpkg/notes/notes" bindtap="onMenuTap">
      <text class="menu-icon">📝</text>
      <text class="menu-title">我的笔记</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider" />
    <view class="menu-item" data-url="/subpkg/history/history" bindtap="onMenuTap">
      <text class="menu-icon">📖</text>
      <text class="menu-title">浏览历史</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-card">
    <view class="menu-item" data-url="/subpkg/ai/ai" bindtap="onMenuTap">
      <text class="menu-icon">🤖</text>
      <text class="menu-title">AI法律助手</text>
      <text class="menu-badge">智能问答</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider" />
    <view class="menu-item" data-url="/subpkg/contact/contact" bindtap="onMenuTap">
      <text class="menu-icon">👨‍⚖️</text>
      <text class="menu-title">联系律师</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="about-card">
    <text class="about-title">关于「遗产通」</text>
    <text class="about-version">版本 2.0.0</text>
    <text class="about-body">深圳市迪莹互联网技术有限公司 出品</text>
    <text class="about-stats">390+全国法院真实判例 · 45条民法典继承编 · 125个法律术语</text>
    <view class="about-divider" />
    <text class="about-sources-title">数据来源</text>
    <view class="source-list">
      <text class="source-line">· 《中华人民共和国民法典》继承编及司法解释</text>
      <text class="source-line">· 中国裁判文书网公开裁判文书（节选整理）</text>
      <text class="source-line">· AI功能由深度合成技术提供，输出仅供参考</text>
    </view>
  </view>

  <view class="privacy-wrap">
    <text class="privacy-btn" bindtap="onPrivacyTap">《隐私政策》</text>
  </view>
</view>
