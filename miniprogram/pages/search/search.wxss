.page {
  min-height: 100vh;
  background: #F7F7F5;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  box-sizing: border-box;
}

.search-header {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #F7F7F5;
  padding: 20rpx 24rpx 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.search-bar {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 18rpx 22rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(43, 95, 138, 0.12);
}

.search-bar-icon {
  font-size: 30rpx;
  margin-right: 14rpx;
  opacity: 0.55;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
  height: 44rpx;
  min-height: 44rpx;
}

.search-ph {
  color: #999999;
}

.hot-section {
  padding: 8rpx 24rpx 32rpx;
}

.hot-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #666666;
  margin-bottom: 20rpx;
  padding-left: 4rpx;
}

.hot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-chip {
  padding: 16rpx 28rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #2B5F8A;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(43, 95, 138, 0.12);
}

.hot-chip:active {
  background: rgba(43, 95, 138, 0.06);
}

.result-list {
  padding: 0 24rpx 24rpx;
}

.result-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 24rpx 26rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.result-card:active {
  opacity: 0.92;
}

.result-top {
  margin-bottom: 12rpx;
}

.badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.badge-law {
  background: rgba(43, 95, 138, 0.12);
  color: #2B5F8A;
}

.badge-case {
  background: rgba(198, 156, 109, 0.2);
  color: #6B4E2E;
}

.badge-faq {
  background: rgba(179, 58, 58, 0.1);
  color: #B33A3A;
}

.badge-topic {
  background: rgba(43, 95, 138, 0.08);
  color: #1A3D5C;
  border: 1rpx solid rgba(43, 95, 138, 0.2);
}

.badge-glossary {
  background: rgba(198, 156, 109, 0.15);
  color: #8B6914;
}

.result-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  line-height: 1.45;
}

.result-sub {
  font-size: 24rpx;
  color: #888888;
  margin-top: 10rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.empty-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 48rpx;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
  opacity: 0.85;
}

.empty-text {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 32rpx;
}

.empty-btn {
  background: #2B5F8A !important;
  color: #fff !important;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx !important;
  padding: 0 40rpx;
  line-height: 80rpx;
  height: 80rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(43, 95, 138, 0.3);
}

.empty-btn::after {
  border: none;
}

.empty-ai-btn {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #667EEA, #764BA2) !important;
  color: #fff !important;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx !important;
  padding: 0 40rpx;
  line-height: 80rpx;
  height: 80rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.3);
}

.empty-ai-btn::after {
  border: none;
}

.hint-block {
  padding: 48rpx 40rpx;
  text-align: center;
}

.hint-text {
  font-size: 26rpx;
  color: #999999;
}
