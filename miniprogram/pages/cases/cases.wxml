<view class="page">
  <view class="filter-block">
    <text class="filter-label">标签</text>
    <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="filter-row">
        <view
          wx:for="{{tagBar}}"
          wx:key="*this"
          class="filter-chip {{(item === '全部' ? !selectedTag : selectedTag === item) ? 'active' : ''}}"
          data-tag="{{item}}"
          bindtap="onTagTap"
        >
          {{item}}
        </view>
      </view>
    </scroll-view>

    <text class="filter-label">案由类型</text>
    <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="filter-row">
        <view
          wx:for="{{typeBar}}"
          wx:key="*this"
          class="filter-chip {{(item === '全部' ? !selectedType : selectedType === item) ? 'active' : ''}}"
          data-type="{{item}}"
          bindtap="onTypeTap"
        >
          {{item}}
        </view>
      </view>
    </scroll-view>

    <view class="picker-row">
      <view class="picker-cell">
        <text class="filter-label tight">裁判年份</text>
        <picker mode="selector" range="{{yearOptions}}" value="{{yearIndex}}" bindchange="onYearChange">
          <view class="picker-trigger">
            <text class="picker-text">{{yearOptions[yearIndex]}}</text>
            <text class="picker-caret">▼</text>
          </view>
        </picker>
      </view>
      <view class="picker-cell">
        <text class="filter-label tight">地域</text>
        <picker mode="selector" range="{{provinceOptions}}" value="{{provinceIndex}}" bindchange="onProvinceChange">
          <view class="picker-trigger">
            <text class="picker-text">{{provinceOptions[provinceIndex]}}</text>
            <text class="picker-caret">▼</text>
          </view>
        </picker>
      </view>
    </view>
  </view>

  <scroll-view class="list-scroll" scroll-y enhanced>
    <view wx:if="{{empty && loaded}}" class="empty-state">
      <text class="empty-icon">📂</text>
      <text class="empty-text">未找到匹配案例</text>
    </view>

    <view
      wx:for="{{caseList}}"
      wx:key="id"
      class="case-card"
      data-id="{{item.id}}"
      bindtap="onCaseTap"
    >
      <text class="case-title">{{item.title}}</text>
      <text class="case-meta">{{item.court}} · {{item.judgeDate}}</text>
      <view class="case-tags">
        <text wx:for="{{item.cardTags}}" wx:for-item="tg" wx:key="*this" class="case-tag">{{tg}}</text>
      </view>
      <text class="case-summary">{{item.summaryBrief}}</text>
    </view>

    <view class="safe-bottom"></view>
  </scroll-view>
</view>
