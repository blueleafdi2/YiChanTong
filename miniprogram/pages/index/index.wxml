<view class="page">
  <view class="header" style="padding-top: {{bannerPaddingTop}}px;">
    <view class="header-inner">
      <text class="header-brand">遗产通</text>
      <view class="header-search" bindtap="onTapSearch">
        <text class="header-search-icon">🔍</text>
      </view>
    </view>
  </view>

  <view class="sheet">
    <view class="search-bar" bindtap="onTapSearch">
      <text class="search-icon" aria-hidden="true">🔍</text>
      <text class="search-placeholder">搜索法条、案例、法律问题…</text>
    </view>

    <view class="ai-card" bindtap="onTapAI">
      <view class="ai-card-left">
        <text class="ai-card-icon">🤖</text>
        <view class="ai-card-text">
          <text class="ai-card-title">AI继承法助手</text>
          <text class="ai-card-desc">有继承法问题？智能为您解答</text>
        </view>
      </view>
      <text class="ai-card-arrow">→</text>
    </view>

    <view class="quick-grid">
      <view class="quick-item" bindtap="onQuickTap" data-tab="laws">
        <text class="quick-icon">📖</text>
        <text class="quick-label">法律库</text>
      </view>
      <view class="quick-item" bindtap="onQuickTap" data-tab="cases">
        <text class="quick-icon">📋</text>
        <text class="quick-label">案例库</text>
      </view>
      <view class="quick-item" bindtap="onQuickTap" data-tab="glossary">
        <text class="quick-icon">📚</text>
        <text class="quick-label">法律词典</text>
      </view>
      <view class="quick-item" bindtap="onQuickTap" data-tab="tools">
        <text class="quick-icon">🔧</text>
        <text class="quick-label">工具箱</text>
      </view>
    </view>

    <scroll-view class="chip-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="chip-row">
        <view
          wx:for="{{quickChips}}"
          wx:key="topicId"
          class="chip"
          data-topicid="{{item.topicId}}"
          bindtap="onTapChip"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>

    <view wx:if="{{newsItem}}" class="news-bar" bindtap="onTapNews">
      <text class="news-badge">动态</text>
      <text class="news-text">{{newsItem.title}}</text>
      <text class="news-arrow">›</text>
    </view>

    <view class="section-head">
      <text class="section-title">精选案例</text>
      <text class="section-more" bindtap="onQuickTap" data-tab="cases">更多 ›</text>
    </view>
    <scroll-view class="case-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="case-scroll-inner">
        <view
          wx:for="{{featuredCases}}"
          wx:key="id"
          class="case-card-h"
          data-id="{{item.id}}"
          bindtap="onTapCase"
        >
          <text class="case-card-title">{{item.title}}</text>
          <text class="case-card-meta">{{item.court}} · {{item.judgeDate}}</text>
          <view class="case-card-tags">
            <text wx:for="{{item.displayTags}}" wx:for-item="tag" wx:key="*this" class="mini-tag">{{tag}}</text>
          </view>
        </view>
      </view>
    </scroll-view>

    <view class="section-head">
      <text class="section-title">热门问题</text>
    </view>
    <view class="faq-list">
      <view
        wx:for="{{faqList}}"
        wx:key="id"
        class="faq-item"
        data-topicid="{{item.relatedTopicId}}"
        data-faqid="{{item.id}}"
        bindtap="onTapFaq"
      >
        <text class="faq-q">{{item.question}}</text>
        <text class="faq-arrow">›</text>
      </view>
    </view>

    <view class="share-bar">
      <text class="share-text">💡 觉得有用？</text>
      <button class="share-btn" open-type="share">分享给朋友</button>
    </view>

    <view class="safe-bottom"></view>
  </view>
</view>
