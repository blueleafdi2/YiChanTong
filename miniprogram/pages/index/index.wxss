.page {
  min-height: 100vh;
  background: #F7F7F5;
}

.hero {
  background: linear-gradient(145deg, #1A3D5C 0%, #2B5F8A 45%, #3A7CB8 100%);
  padding-left: 40rpx;
  padding-right: 40rpx;
  padding-bottom: 48rpx;
  border-radius: 0 0 32rpx 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(43, 95, 138, 0.25);
}

.hero-inner {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-brand {
  font-size: 52rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 4rpx;
}

.hero-tagline {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.88);
  font-weight: 400;
}

.sheet {
  margin-top: -24rpx;
  position: relative;
  z-index: 1;
}

.search-bar {
  display: flex;
  align-items: center;
  margin: 0 24rpx 24rpx;
  padding: 22rpx 28rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 30rpx;
  margin-right: 16rpx;
  opacity: 0.55;
}

.search-placeholder {
  font-size: 28rpx;
  color: #999999;
}

.chip-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.chip-row {
  display: inline-flex;
  padding: 0 24rpx;
  gap: 16rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 28rpx;
  background: #ffffff;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #2B5F8A;
  border: 1rpx solid rgba(43, 95, 138, 0.2);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  flex-shrink: 0;
}

.ai-card {
  margin: 0 24rpx 32rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 8rpx 28rpx rgba(198, 156, 109, 0.35);
}

.ai-card-glow {
  position: absolute;
  inset: 0;
  background: linear-gradient(125deg, #C69C6D 0%, #D4A96A 40%, #E8D5B5 100%);
  opacity: 1;
}

.ai-card-body {
  position: relative;
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  gap: 20rpx;
}

.ai-badge {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #c69c6d;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 64rpx;
  text-align: center;
  flex-shrink: 0;
}

.ai-texts {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.ai-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.ai-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.92);
}

.ai-arrow {
  font-size: 44rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 300;
  line-height: 1;
}

.section-head {
  padding: 8rpx 24rpx 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 30rpx;
  background: #C69C6D;
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.case-spotlight {
  margin: 0 24rpx 32rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border-left: 6rpx solid #B33A3A;
}

.case-spotlight-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.45;
  margin-bottom: 10rpx;
}

.case-spotlight-meta {
  display: block;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.case-spotlight-summary {
  font-size: 26rpx;
  color: #444444;
  line-height: 1.55;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.case-spotlight-tags {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.mini-tag {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  background: rgba(43, 95, 138, 0.1);
  color: #2B5F8A;
}

.empty-inline {
  margin: 0 24rpx 32rpx;
  padding: 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999999;
  background: #ffffff;
  border-radius: 16rpx;
}

.faq-list {
  margin: 0 24rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.faq-item {
  display: flex;
  align-items: center;
  padding: 26rpx 24rpx;
  border-bottom: 1rpx solid #f0ede8;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-q {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
  line-height: 1.5;
  padding-right: 12rpx;
}

.faq-arrow {
  font-size: 32rpx;
  color: #cccccc;
  flex-shrink: 0;
}

.topic-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 16rpx 32rpx;
  gap: 16rpx;
}

.topic-cell {
  width: calc(50% - 24rpx);
  margin: 0 8rpx;
  box-sizing: border-box;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.topic-emoji {
  font-size: 40rpx;
  line-height: 1.2;
}

.topic-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.35;
}

.topic-desc {
  font-size: 22rpx;
  color: #666666;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.safe-bottom {
  height: calc(env(safe-area-inset-bottom) + 24rpx);
}
