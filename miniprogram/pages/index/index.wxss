.page {
  min-height: 100vh;
  background: #F7F7F5;
}

.header {
  background: linear-gradient(145deg, #1A3D5C 0%, #2B5F8A 45%, #3A7CB8 100%);
  padding-left: 40rpx;
  padding-right: 40rpx;
  padding-bottom: 36rpx;
  border-radius: 0 0 32rpx 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(43, 95, 138, 0.25);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-brand {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 4rpx;
}

.header-search {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-search-icon {
  font-size: 28rpx;
}

.sheet {
  margin-top: -16rpx;
  position: relative;
  z-index: 1;
}

.search-bar {
  display: flex;
  align-items: center;
  margin: 0 24rpx 20rpx;
  padding: 22rpx 28rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 30rpx;
  margin-right: 16rpx;
  opacity: 0.55;
}

.search-placeholder {
  font-size: 28rpx;
  color: #999999;
}

/* AI Entry Card */
.ai-card {
  margin: 0 24rpx 24rpx;
  padding: 28rpx 24rpx;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.35);
}

.ai-card-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.ai-card-icon {
  font-size: 44rpx;
}

.ai-card-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.ai-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
}

.ai-card-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.ai-card-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 300;
}

/* Quick Grid */
.quick-grid {
  display: flex;
  justify-content: space-around;
  margin: 0 24rpx 24rpx;
  padding: 24rpx 0;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.quick-icon {
  font-size: 40rpx;
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #F0F4F8;
  border-radius: 50%;
}

.quick-label {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
}

/* Chips */
.chip-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.chip-row {
  display: inline-flex;
  padding: 0 24rpx;
  gap: 16rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 28rpx;
  background: #ffffff;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #2B5F8A;
  border: 1rpx solid rgba(43, 95, 138, 0.2);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  flex-shrink: 0;
}

/* News Bar */
.news-bar {
  margin: 0 24rpx 20rpx;
  padding: 18rpx 24rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.news-badge {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  background: #FF6B35;
  color: #ffffff;
  border-radius: 6rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.news-text {
  flex: 1;
  font-size: 26rpx;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.news-arrow {
  font-size: 28rpx;
  color: #999999;
  flex-shrink: 0;
}

/* Section */
.section-head {
  padding: 8rpx 24rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 30rpx;
  background: #2B5F8A;
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.section-more {
  font-size: 26rpx;
  color: #2B5F8A;
}

/* Horizontal Case Cards */
.case-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.case-scroll-inner {
  display: inline-flex;
  padding: 0 24rpx;
  gap: 16rpx;
}

.case-card-h {
  width: 520rpx;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border-left: 6rpx solid #B33A3A;
  white-space: normal;
  display: inline-flex;
  flex-direction: column;
  flex-shrink: 0;
}

.case-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.45;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.case-card-meta {
  font-size: 22rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.case-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.mini-tag {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  background: rgba(43, 95, 138, 0.1);
  color: #2B5F8A;
}

/* FAQ */
.faq-list {
  margin: 0 24rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.faq-item {
  display: flex;
  align-items: center;
  padding: 26rpx 24rpx;
  border-bottom: 1rpx solid #f0ede8;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-q {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
  line-height: 1.5;
  padding-right: 12rpx;
}

.faq-arrow {
  font-size: 32rpx;
  color: #cccccc;
  flex-shrink: 0;
}

/* Share Bar */
.share-bar {
  margin: 8rpx 24rpx 0;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.share-text {
  font-size: 26rpx;
  color: #666666;
}

.share-btn {
  font-size: 26rpx;
  color: #2B5F8A;
  background: rgba(43, 95, 138, 0.1);
  border-radius: 32rpx;
  padding: 12rpx 28rpx;
  border: none;
  line-height: 1.4;
}

.share-btn::after {
  border: none;
}

.safe-bottom {
  height: calc(env(safe-area-inset-bottom) + 24rpx);
}
