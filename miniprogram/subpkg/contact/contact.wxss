.page {
  padding: 24rpx 0 48rpx;
  min-height: 100vh;
  background: var(--bg);
}

.intro { margin: 0 24rpx 24rpx; }

.intro-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
  display: block;
  margin-bottom: 12rpx;
}

.intro-body {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.65;
}

.contact-card { margin: 0 24rpx 24rpx; }

.contact-head { margin-bottom: 12rpx; }

.contact-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.contact-tag {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  background: rgba(198, 156, 109, 0.25);
  color: var(--primary-dark);
  font-weight: 500;
}

.tag-hotline {
  background: rgba(43, 95, 138, 0.12);
  color: var(--primary);
}

.contact-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 2rpx;
  display: block;
  margin-bottom: 8rpx;
}

.contact-value.phone { color: var(--primary); }
.contact-value.email { font-size: 30rpx; color: var(--primary); }

.sub {
  display: block;
  margin-bottom: 24rpx;
  color: var(--text-secondary);
}

.full-btn {
  width: 100%;
  margin: 0;
  border-radius: 16rpx;
}

.full-btn::after { border: none; }

.call-btn { margin-top: 8rpx; }

.footer-note {
  padding: 8rpx 24rpx 0;
  text-align: center;
  color: var(--text-hint);
  line-height: 1.5;
}

.px { padding-left: 24rpx; padding-right: 24rpx; }
