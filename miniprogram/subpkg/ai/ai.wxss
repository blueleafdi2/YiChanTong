.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg);
}

.chat-scroll {
  flex: 1;
  height: 0;
}

.chat-inner {
  padding: 24rpx 24rpx 16rpx;
}

.hint {
  margin-bottom: 24rpx;
}

.hint-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--primary);
  display: block;
  margin-bottom: 12rpx;
}

.hint-body {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.msg-row {
  display: flex;
  margin-bottom: 24rpx;
}

.msg-row--user {
  justify-content: flex-end;
}

.msg-row--ai {
  justify-content: flex-start;
  flex-direction: column;
  align-items: flex-start;
}

.bubble {
  max-width: 85%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.65;
  word-break: break-word;
}

.bubble-user {
  background: var(--primary);
  color: #fff;
  border-bottom-right-radius: 6rpx;
}

.bubble-ai {
  background: var(--surface);
  color: var(--text-primary);
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow);
  border-bottom-left-radius: 6rpx;
}

.thinking {
  color: var(--text-secondary);
  font-style: italic;
}

.chips {
  margin-top: 12rpx;
  max-width: 100%;
}

.chips-label {
  font-size: 22rpx;
  color: var(--text-hint);
  display: block;
  margin-bottom: 8rpx;
}

.chips-scroll {
  white-space: nowrap;
  max-width: 100%;
}

.chip {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  margin-right: 12rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
}

.chip-law {
  background: rgba(43, 95, 138, 0.1);
  color: var(--primary);
  font-weight: 500;
}

.chip-case {
  background: rgba(179, 58, 58, 0.1);
  color: var(--accent);
  font-weight: 500;
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.scroll-spacer {
  height: 24rpx;
}

.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx calc(env(safe-area-inset-bottom) + 16rpx);
  gap: 16rpx;
  background: var(--surface);
  border-top: 1rpx solid var(--border);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.04);
  flex-shrink: 0;
}

.input-field {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  background: var(--bg);
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.send-btn {
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: var(--primary);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 16rpx;
  flex-shrink: 0;
  text-align: center;
}

.send-btn.disabled {
  opacity: 0.5;
  pointer-events: none;
}
