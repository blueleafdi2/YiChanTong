.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg);
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  padding-bottom: 8rpx;
}

.toolbar-tip {
  color: var(--text-secondary);
}

.clear-btn {
  margin: 0;
  padding: 0 24rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  color: var(--accent);
  background: rgba(179, 58, 58, 0.08);
  border-radius: 16rpx;
  border: none;
}

.clear-btn::after {
  border: none;
}

.clear-btn[disabled] {
  opacity: 0.35;
  color: var(--text-hint);
}

.scroll {
  flex: 1;
  height: 0;
}

.row {
  margin: 16rpx 24rpx;
}

.row--hover {
  opacity: 0.92;
}

.row-top {
  margin-bottom: 12rpx;
}

.type-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 600;
  color: #fff;
}

.type-law {
  background: var(--primary);
}

.type-case {
  background: #5c6bc0;
}

.type-topic {
  background: var(--gold);
  color: var(--primary-dark);
}

.type-faq {
  background: #00897b;
}

.type-tool {
  background: #6d4c41;
}

.time {
  color: var(--text-hint);
}

.row-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.45;
  display: block;
}

.px {
  padding-left: 24rpx;
  padding-right: 24rpx;
}
