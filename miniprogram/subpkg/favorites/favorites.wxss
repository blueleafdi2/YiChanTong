.page {
  height: 100vh;
  background: var(--bg);
}

.scroll {
  height: 100%;
  box-sizing: border-box;
}

.swipe {
  position: relative;
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.swipe-back {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 168rpx;
  background: var(--accent);
  display: flex;
  align-items: stretch;
  justify-content: flex-end;
}

.swipe-del {
  width: 168rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.swipe-front {
  position: relative;
  z-index: 1;
  background: transparent;
}

.row {
  margin: 0;
}

.row-top {
  margin-bottom: 12rpx;
}

.type-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 600;
  color: #fff;
}

.type-law {
  background: var(--primary);
}

.type-case {
  background: #5c6bc0;
}

.type-topic {
  background: var(--gold);
  color: var(--primary-dark);
}

.type-faq {
  background: #00897b;
}

.type-tool {
  background: #6d4c41;
}

.time {
  color: var(--text-hint);
}

.row-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.45;
  display: block;
}

.hint {
  display: block;
  margin-top: 8rpx;
  color: var(--text-hint);
}
